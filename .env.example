OPENAI_API_KEY=
DEBUG=false

APP_NAME=career-pilot-ai
SERVER_PORT=8080

OPENAI_TEMPERATURE=0
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MODEL_RESUME_ANALYSIS=gpt-5-nano
OPENAI_MODEL_JOB_MATCHING=gpt-5-mini
OPENAI_MODEL_SKILL_GAP=gpt-5-mini
OPENAI_MODEL_STUDY_PLANNING=gpt-5-mini

# Study plan RAG (learning_resources.jsonl)
STUDY_PLAN_RAG_TOP_K=5
# Optional: absolute path to learning_resources.jsonl. Leave unset to use packaged data/.
# Do NOT set to empty (LEARNING_RESOURCES_PATH=) — that disables loading.
# LEARNING_RESOURCES_PATH=
